<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#FF2E2E2E"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#FF1A1A1A"
                android:endColor="#FF3E3E3E"
                android:angle="90"
                android:type="linear" />
        </shape>
    </item>
    <item>
        <shape>
            <stroke
                android:width="2dp"
                android:color="#FFFF5252" />
        </shape>
    </item>
</layer-list>