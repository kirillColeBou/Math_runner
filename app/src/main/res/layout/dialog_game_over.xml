<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@drawable/dialog_background">

    <!-- Заголовок -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ПОРАЖЕНИЕ"
        android:textColor="#FFFF5252"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Неправильный ответ!"
        android:textColor="#FFB0BEC5"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <!-- Разделитель -->
    <View
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:background="#FFFF5252"
        android:layout_marginBottom="20dp" />

    <!-- Очки -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Счёт: "
            android:textColor="#FF81C784"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_final_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFD700"
            android:textSize="24sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Рекорд -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Рекорд: "
            android:textColor="#FF81C784"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_best_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="342"
            android:textColor="#FFFFD700"
            android:textSize="24sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Кнопки -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Играть снова -->
        <LinearLayout
            android:id="@+id/btn_restart"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/btn_pause_resume"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:elevation="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↻"
                android:textColor="#FFFFFFFF"
                android:textSize="32sp" />

        </LinearLayout>

        <!-- Выйти -->
        <LinearLayout
            android:id="@+id/btn_exit_game"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/btn_pause_exit"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:elevation="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="#FFFFFFFF"
                android:textSize="32sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>