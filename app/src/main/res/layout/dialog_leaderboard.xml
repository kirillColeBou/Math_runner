<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="20dp">

    <!-- Заголовок -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ТОП ИГРОКОВ"
        android:textColor="#FFFFD700"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Разделитель -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FF2A3540"
        android:layout_marginBottom="12dp" />

    <!-- Заголовки колонок -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="#FF81C784"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Игрок"
            android:textColor="#FF81C784"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Очки"
            android:textColor="#FF81C784"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="end" />

    </LinearLayout>

    <!-- Список игроков -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="300dp">

        <LinearLayout
            android:id="@+id/container_top_players"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <!-- Разделитель -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FF00E676"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Место текущего игрока -->
    <LinearLayout
        android:id="@+id/container_my_place"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            android:background="#FF1E3A2B">

            <TextView
                android:id="@+id/tv_my_rank"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="102"
                android:textColor="#FF00E676"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Вы"
                android:textColor="#FF00E676"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_my_score"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FF00E676"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- Кнопка закрыть -->
    <TextView
        android:id="@+id/btn_close_leaderboard"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/btn_cancel_background"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="ЗАКРЫТЬ"
        android:textColor="#FFB0BEC5"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>