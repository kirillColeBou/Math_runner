<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <style name="RecordContainer">
        <item name="android:background">@drawable/record_background</item>
        <item name="android:padding">@dimen/padding_medium</item>
        <item name="android:layout_margin">@dimen/padding_large</item>
    </style>

    <style name="RecordLabel">
        <item name="android:textColor">@color/accent_green_light</item>
        <item name="android:textSize">@dimen/text_record_title</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="RecordValue">
        <item name="android:textColor">@color/gold</item>
        <item name="android:textSize">@dimen/text_record_value</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:layout_marginTop">@dimen/padding_small</item>
    </style>

    <style name="StartButton">
        <item name="android:background">@drawable/button_start_background</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:paddingTop">@dimen/padding_medium</item>
        <item name="android:paddingBottom">@dimen/padding_medium</item>
        <item name="android:paddingLeft">50dp</item>
        <item name="android:paddingRight">50dp</item>
        <item name="android:elevation">8dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="NavButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_nav</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="NavIcon">
        <item name="android:background">@drawable/nav_icon_background</item>
        <item name="android:layout_gravity">center</item>
    </style>
</resources>